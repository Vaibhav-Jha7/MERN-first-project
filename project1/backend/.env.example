# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/event_booking

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Nodemailer (Gmail example - use an "App Password", not your normal password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Event Booking <your_email@gmail.com>"

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# One-time secret to allow creating the first admin account via API
ADMIN_SIGNUP_SECRET=letmein_admin_2026
